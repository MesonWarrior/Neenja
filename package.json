{
  "name": "neenja",
  "version": "1.0.0",
  "description": "CLI for viewing, and building single-file documentation for coding agents.",
  "bin": {
    "neenja": "./bin/neenja.mjs"
  },
  "files": [
    "astro.config.mjs",
    "bin",
    "components",
    "lib",
    "skills",
    "public",
    "src",
    "tsconfig.json"
  ],
  "license": "MIT",
  "keywords": [
    "ai",
    "agent",
    "cli",
    "documentation",
    "knowledge-base",
    "neenja"
  ],
  "homepage": "https://github.com/MesonWarrior/Neenja#readme",
  "bugs": {
    "url": "https://github.com/MesonWarrior/Neenja/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MesonWarrior/Neenja.git"
  },
  "engines": {
    "node": "18.20.8 || ^20.3.0 || >=22.0.0"
  },
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "build:github-pages": "PUBLIC_SITE_URL=https://your_name.github.io PUBLIC_BASE_PATH=/your_page/ node ./bin/neenja.mjs build-github",
    "start": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "typecheck": "ASTRO_TELEMETRY_DISABLED=1 astro check"
  },
  "dependencies": {
    "@astrojs/react": "4.4.2",
    "astro": "5.18.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.0.0"
  }
}
