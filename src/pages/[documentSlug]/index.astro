---
import { DocsShell } from "../../../components/docs-shell";
import {
  getReaderDocumentDescription,
  readDocumentCollection,
} from "../../../lib/documentation-file";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const collection = await readDocumentCollection();

  return collection.documents.map((document) => ({
    params: {
      documentSlug: document.slug,
    },
  }));
}

const collection = await readDocumentCollection();
const { documentSlug } = Astro.params;
const document = documentSlug ? collection.documentsBySlug[documentSlug] : undefined;

if (!document) {
  throw new Error(`Unknown document: ${documentSlug ?? "missing"}`);
}

const firstEntryId =
  document.kind === "documentation"
    ? document.concepts[0]?.id
    : document.kind === "project-plan"
      ? document.sections[0]?.id
      : undefined;
const basePath = import.meta.env.BASE_URL;
const brandIconSrc = `${basePath}brand/neenja.svg`;
---

<BaseLayout
  title={document.meta.title}
  description={getReaderDocumentDescription(document)}
  iconHref={brandIconSrc}
>
  <DocsShell
    client:load
    collection={collection}
    selectedDocumentSlug={document.slug}
    selectedEntryId={firstEntryId}
    homeHref={basePath}
    basePath={basePath}
    brandIconSrc={brandIconSrc}
  />
</BaseLayout>
