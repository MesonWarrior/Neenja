---
import { DocsShell } from "../../../components/docs-shell";
import { readDocumentCollection } from "../../../lib/documentation-file";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const collection = await readDocumentCollection();

  return collection.documents.flatMap((document) => {
    const entries =
      document.kind === "documentation"
        ? document.concepts.map((concept) => ({
            id: concept.id,
            title: concept.title,
            summary: concept.summary,
          }))
        : document.kind === "project-plan"
          ? document.sections.map((section) => ({
              id: section.id,
              title: section.title,
              summary: section.summary,
            }))
          : document.tasks.map((task) => ({
              id: task.id,
              title: task.title,
              summary: task.content || document.meta.summary,
            }));

    return entries.map((entry) => ({
      params: {
        documentSlug: document.slug,
        entryId: entry.id,
      },
      props: {
        title: entry.title,
        summary: entry.summary,
      },
    }));
  });
}

const collection = await readDocumentCollection();
const { documentSlug, entryId } = Astro.params;
const document = documentSlug ? collection.documentsBySlug[documentSlug] : undefined;

if (!document) {
  throw new Error(`Unknown document: ${documentSlug ?? "missing"}`);
}

const entry =
  document.kind === "documentation"
    ? document.conceptsById[entryId ?? ""]
    : document.kind === "project-plan"
      ? document.sectionsById[entryId ?? ""]
      : document.tasksById[entryId ?? ""];

if (!entry) {
  throw new Error(`Unknown entry: ${entryId ?? "missing"}`);
}

const entryDescription =
  document.kind === "documentation"
    ? document.conceptsById[entryId ?? ""]?.summary
    : document.kind === "project-plan"
      ? document.sectionsById[entryId ?? ""]?.summary
      : document.tasksById[entryId ?? ""]?.content || document.meta.summary;

const basePath = import.meta.env.BASE_URL;
const brandIconSrc = `${basePath}brand/neenja.svg`;
---

<BaseLayout
  title={`${document.meta.title} / ${entry.title}`}
  description={entryDescription || document.meta.summary}
  iconHref={brandIconSrc}
>
  <DocsShell
    client:load
    collection={collection}
    selectedDocumentSlug={document.slug}
    selectedEntryId={entry.id}
    homeHref={basePath}
    basePath={basePath}
    brandIconSrc={brandIconSrc}
  />
</BaseLayout>
