---
import { DocsShell } from "../../components/docs-shell";
import { readKnowledgeDocument } from "../../lib/knowledge-file";
import BaseLayout from "../layouts/BaseLayout.astro";

const document = await readKnowledgeDocument();
const firstConceptId = document.concepts[0]?.id;
const basePath = import.meta.env.BASE_URL;
const brandIconSrc = `${basePath}brand/neenja.svg`;
---

<BaseLayout
  title={document.meta.title}
  description={document.meta.summary}
  iconHref={brandIconSrc}
>
  <DocsShell
    client:load
    document={document}
    selectedConceptId={firstConceptId}
    homeHref={basePath}
    basePath={basePath}
    brandIconSrc={brandIconSrc}
  />
</BaseLayout>
